# ForenseID - Backend Environment Variables
# Copia este archivo a .env y rellena tus valores.

# Server
PORT=4000
NODE_ENV=development

# Auth
# API key aceptada por: X-API-Key, Authorization: Bearer, ?api_key=, body.api_key
API_KEY=forenseid_demo_key_2026

# JWT (para tokens/reporte). Usa un secreto fuerte en producción.
JWT_SECRET=change_me_super_secret

# Database (Prisma + SQLite)
# Si no se define, el backend usará backend/prisma/dev.db automáticamente.
# DATABASE_URL=file:./prisma/dev.db

# Google Cloud (Document AI + Vision)
# Recomendado: ruta ABSOLUTA al JSON de service account.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/forenseid-service-account.json

# Document AI Processor
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us
GCP_PROCESSOR_ID=your-processor-id

# Cloudinary (para /documents/analyze-advanced)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret