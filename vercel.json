{
  "version": 2,
  "public": false,
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node@3.0.0",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "20.x"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build@2.3.0",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/app.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/api-docs(.*)",
      "dest": "/backend/src/app.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html",
      "status": 200
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "4000"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
